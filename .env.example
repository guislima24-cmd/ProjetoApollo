# ─── Google Sheets (obrigatório) ──────────────────────────────────────────────
# Opção A (preferida): o JSON inteiro do service account em uma única env.
# Gera-se no Google Cloud Console → Service Accounts → Keys → Add key → JSON.
GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"apollo-sheets@seu-projeto.iam.gserviceaccount.com",...}'

# Opção B (fallback): par email + chave PEM separados.
# A chave aceita \n literais (o app converte pra quebras de linha reais).
# GOOGLE_SERVICE_ACCOUNT_EMAIL="apollo-sheets@seu-projeto.iam.gserviceaccount.com"
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Planilha do pipeline (aba "Leads")
GOOGLE_SHEETS_ID="1A...xyz"

# Planilha comercial com as 11 abas por membro.
# Se omitido, cai pra GOOGLE_SHEETS_ID.
GOOGLE_MEMBER_SHEETS_ID="1B...abc"

# ─── Claude (obrigatório) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Auth (obrigatório) ───────────────────────────────────────────────────────
# 32+ chars aleatórios. Gere com: openssl rand -hex 32
JWT_SECRET="cole-aqui-32-ou-mais-caracteres-aleatorios"

# Pares username:sha256(senha+JWT_SECRET) separados por |.
# Gere cada hash com:
#   JWT_SECRET="..." node scripts/hash-password.mjs <user> "<senha>"
# Usernames válidos: anna, daniel, duda, felipe, gui-lima, gui-midolli,
# gustavo, larissa, leo, leticia, tiago
MEMBER_CREDENTIALS="anna:abc...|daniel:def...|duda:...|felipe:...|gui-lima:...|gui-midolli:...|gustavo:...|larissa:...|leo:...|leticia:...|tiago:..."

# ─── Setup (temporário) ───────────────────────────────────────────────────────
# Libera a página /setup/hash para gerar as linhas do MEMBER_CREDENTIALS pelo
# navegador (sem precisar rodar script local). Deixe "true" só durante a
# configuração inicial e REMOVA depois.
# ENABLE_HASH_SETUP="true"

# ─── Opcional ─────────────────────────────────────────────────────────────────
# Envio de email via /api/send
# RESEND_API_KEY="re_..."
